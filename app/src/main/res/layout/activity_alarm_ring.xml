<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Pulsing circles -->
    <View android:id="@+id/circle_pulse_3" android:layout_width="280dp" android:layout_height="280dp" android:background="@drawable/bg_circle_light" android:alpha="0.1"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/tv_time" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <View android:id="@+id/circle_pulse_2" android:layout_width="220dp" android:layout_height="220dp" android:background="@drawable/bg_circle_light" android:alpha="0.15"
        app:layout_constraintTop_toTopOf="@id/circle_pulse_3" app:layout_constraintBottom_toBottomOf="@id/circle_pulse_3" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <View android:id="@+id/circle_pulse_1" android:layout_width="160dp" android:layout_height="160dp" android:background="@drawable/bg_circle_light" android:alpha="0.25"
        app:layout_constraintTop_toTopOf="@id/circle_pulse_3" app:layout_constraintBottom_toBottomOf="@id/circle_pulse_3" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Alarm Icon -->
    <ImageView
        android:id="@+id/iv_alarm_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_alarm"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="@id/circle_pulse_3"
        app:layout_constraintBottom_toBottomOf="@id/circle_pulse_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Time Display -->
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="72sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Label -->
    <TextView
        android:id="@+id/tv_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰ Alarm"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:alpha="0.9"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_time"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:layout_marginBottom="60dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_snooze"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Snooze 5 min"
            android:textColor="@color/primary"
            android:textSize="14sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="20dp"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dismiss"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Dismiss"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="#40FFFFFF"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp"
            app:cornerRadius="20dp"
            android:layout_marginStart="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
